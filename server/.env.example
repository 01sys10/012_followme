# ── LLM 설정 ─────────────────────────────────────────────────────────────────
# "openai" 또는 "ollama" 중 선택
LLM_PROVIDER=openai

# OpenAI (LLM_PROVIDER=openai 일 때 사용)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (LLM_PROVIDER=ollama 일 때 사용, t3.medium 이상 권장)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# ── 날씨 API ──────────────────────────────────────────────────────────────────
# https://openweathermap.org 에서 무료 발급
WEATHER_API_KEY=
WEATHER_CITY=Seoul
